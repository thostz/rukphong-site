# LINE Bot Credentials
# สร้างได้ที่ https://developers.line.biz/console/
LINE_CHANNEL_SECRET=your_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here

# Google Sheets
# ID ของ Google Sheet (เอาจาก URL: docs.google.com/spreadsheets/d/[SPREADSHEET_ID]/edit)
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Apps Script Web App URL
# Deploy → New Deployment → Web App URL
GS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzgn1rNxQ9MB-65dxuj-68c_MIbOHtnwBKXI-VSx54YM50fZ8t162r2Isb6UIcrdYXAoA/exec

# Gemini API Key (AI classification + Slip OCR)
# รับฟรีที่ https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Port (ค่าเริ่มต้น 5000)
PORT=5000
